    "@packages/styles": "workspace:*",
    "@packages/types": "workspace:*",
    "@packages/utils": "workspace:*",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@tdesign-vue-next/nuxt": "^0.1.5",
    "@unocss/nuxt": "^66.6.8"
  }
